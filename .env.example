DATABASE_URL=postgres://talkara:talkara@localhost:5432/talkara

# Optional: disable TLS for pg (local Docker). Railway/managed DBs use TLS by default in src/db/client.ts.
# PGSSLMODE=disable

# Optional: force-disable SSL for non-local URLs (rare).
# DATABASE_SSL=0

# Production (e.g. Railway): Astro Node adapter reads PORT and HOST; Railway sets PORT automatically.
# HOST=0.0.0.0

