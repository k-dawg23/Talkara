---
import Layout from "../../layouts/Layout.astro";
import { getNickname, getOrSetClientId } from "../../server/cookies";
import { getOrCreateLobby, getRoomBySlug, listRooms } from "../../server/rooms";
import { db } from "../../db/client";
import { messages } from "../../db/schema";
import { eq, desc } from "drizzle-orm";
import { renderMessageLi } from "../../server/render";

export const prerender = false;

const nickname = getNickname(Astro.cookies);
if (!nickname) {
  return Astro.redirect("/nick");
}

getOrSetClientId(Astro.cookies);

await getOrCreateLobby();

const { slug } = Astro.params;
const room = await getRoomBySlug(slug!);
if (!room) {
  return Astro.redirect("/rooms/lobby");
}

const rooms = await listRooms();

const recent = await db
  .select()
  .from(messages)
  .where(eq(messages.roomId, room.id))
  .orderBy(desc(messages.createdAt))
  .limit(50);
const initialMessages = [...recent].reverse();
const oldest = initialMessages[0]?.createdAt ?? null;
---

<Layout title={`${room.name} — Talkara`}>
  <div
    class="flex min-h-screen flex-col bg-zinc-950"
    hx-ext="sse"
    sse-connect={`/rooms/${room.slug}/stream`}
  >
    <header class="sticky top-0 z-10 border-b border-zinc-900 bg-zinc-950/80 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-4 py-3">
        <div class="min-w-0">
          <div class="text-xs text-zinc-400">Room</div>
          <div class="truncate text-base font-semibold">{room.name}</div>
        </div>
        <a href="/nick" class="text-sm text-zinc-300 hover:text-white">Change nickname</a>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-4 px-4 py-4 lg:flex-row">
      <aside class="order-2 w-full lg:order-1 lg:w-64">
        <div class="rounded-xl border border-zinc-900 bg-zinc-950 p-3">
          <div class="mb-2 flex items-center justify-between">
            <div class="text-sm font-semibold">Rooms</div>
          </div>

          <ul
            id="roomsList"
            class="flex flex-col gap-1"
            hx-get={`/rooms/list?current=${encodeURIComponent(room.slug)}`}
            hx-trigger="load, sse:roomsUpdated"
            hx-swap="innerHTML"
          >
            {rooms.map((r) => (
              <li>
                <a
                  href={`/rooms/${r.slug}`}
                  class:list={[
                    "block rounded-lg px-2 py-1.5 text-sm hover:bg-zinc-900",
                    r.slug === room.slug ? "bg-zinc-900 text-white" : "text-zinc-300",
                  ]}
                >
                  {r.name}
                </a>
              </li>
            ))}
          </ul>

          <form method="post" action="/rooms" class="mt-3 flex gap-2">
            <input
              name="name"
              required
              maxlength="32"
              class="min-w-0 flex-1 rounded-lg border border-zinc-800 bg-zinc-950 px-2 py-1.5 text-sm text-zinc-100 outline-none focus:border-zinc-600"
              placeholder="New room"
            />
            <button
              class="rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-zinc-900 hover:bg-zinc-100"
              type="submit"
            >
              Create
            </button>
          </form>
        </div>

        <div class="mt-3 rounded-xl border border-zinc-900 bg-zinc-950 p-3">
          <div id="presence">
            <div class="mb-2 text-sm font-semibold">Online</div>
            <div class="text-xs text-zinc-500">Loading…</div>
          </div>
        </div>
      </aside>

      <section class="order-1 flex min-h-[60vh] w-full flex-1 flex-col rounded-xl border border-zinc-900 bg-zinc-950 lg:order-2">
        <div
          id="typing"
          class="h-8 px-3 py-2 text-xs text-zinc-400"
        ></div>

        <ol
          id="messages"
          class="flex-1 overflow-y-auto px-3 py-3"
        >
          <li
            id="historySentinel"
            class="py-2 text-center text-xs text-zinc-500"
            hx-get={`/rooms/${room.slug}/history?before=${encodeURIComponent(oldest ? oldest.toISOString() : new Date().toISOString())}&limit=50`}
            hx-trigger="revealed"
            hx-swap="outerHTML"
          >
            {oldest ? "Load older messages…" : "No history yet"}
          </li>
          {initialMessages.length === 0 ? (
            <li class="text-sm text-zinc-500">No messages yet.</li>
          ) : (
            initialMessages.map((m) => (
              <Fragment set:html={renderMessageLi({ nickname: m.nickname, body: m.body, createdAt: m.createdAt, kind: m.kind })} />
            ))
          )}
        </ol>

        <div
          id="sseSink"
          class="hidden"
          sse-swap="message"
          hx-swap="beforeend"
        ></div>

        <form
          id="composerForm"
          class="flex items-end gap-2 border-t border-zinc-900 p-3"
          hx-post={`/rooms/${room.slug}/messages`}
          hx-target="#sseSink"
          hx-swap="beforeend"
          hx-on:submit="setTimeout(()=>{const t=document.getElementById('composerInput'); if(t){t.value=''; t.dispatchEvent(new Event('input',{bubbles:true}));}},0)"
          hx-on:messageSent="this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}"
          hx-on:htmx:afterRequest="if(event.detail.successful){this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}}"
        >
          <textarea
            id="composerInput"
            name="body"
            rows="1"
            required
            maxlength="2000"
            class="min-h-[44px] flex-1 resize-none rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm text-zinc-100 outline-none focus:border-zinc-600"
            placeholder="Message as {nickname}…"
            hx-post={`/rooms/${room.slug}/typing`}
            hx-trigger="keyup changed delay:400ms"
            hx-swap="none"
            hx-on:keydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); this.form.requestSubmit();}"
          ></textarea>
          <button
            class="h-[44px] rounded-lg bg-white px-4 text-sm font-medium text-zinc-900 hover:bg-zinc-100"
            type="submit"
          >
            Send
          </button>
        </form>
      </section>
    </main>
  </div>
</Layout>

