---
import Layout from "../../layouts/Layout.astro";
import { getNickname, getOrSetClientId } from "../../server/cookies";
import { getOrCreateLobby, getRoomBySlug, listRooms } from "../../server/rooms";
import { db } from "../../db/client";
import { messages } from "../../db/schema";
import { eq, desc, and, ne } from "drizzle-orm";
import { renderMessageLi } from "../../server/render";

export const prerender = false;

const nickname = getNickname(Astro.cookies);
if (!nickname) {
  return Astro.redirect("/nick");
}

getOrSetClientId(Astro.cookies);

await getOrCreateLobby();

const { slug } = Astro.params;
const room = await getRoomBySlug(slug!);
if (!room) {
  return Astro.redirect("/rooms/lobby");
}

const rooms = await listRooms();

const recent = await db
  .select()
  .from(messages)
  .where(and(eq(messages.roomId, room.id), ne(messages.kind, "system")))
  .orderBy(desc(messages.createdAt))
  .limit(50);
const initialMessages = [...recent].reverse();
const oldest = initialMessages[0]?.createdAt ?? null;
---

<Layout title={`${room.name} — Talkara`}>
  <div
    id="chatApp"
    data-active-tab="chat"
    data-chat-nickname={nickname}
    data-room-slug={room.slug}
    data-room-name={room.name}
    class="flex h-screen flex-col bg-tc-950"
    hx-ext="sse"
    sse-connect={`/rooms/${room.slug}/stream`}
  >
    <!-- ─── Header ─── -->
    <header class="flex shrink-0 items-center gap-3 border-b border-tc-800 bg-tc-900/80 px-4 py-2.5 backdrop-blur">
      <a href="/rooms/lobby" class="shrink-0">
        <img src="/logo.svg" alt="Talkara" class="h-8 w-8 rounded-lg" />
      </a>
      <div class="min-w-0 flex-1">
        <div class="truncate text-base font-semibold text-tc-50">{room.name}</div>
      </div>
      <button
        type="button"
        id="mentionNotifyBtn"
        class="shrink-0 rounded-lg p-1.5 text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        title="Enable browser notifications when you are @mentioned"
        aria-label="Enable mention notifications"
      >
        <span class="text-base" aria-hidden="true">🔔</span>
      </button>
      <button
        id="themeToggle"
        onclick="toggleTheme()"
        class="shrink-0 rounded-lg p-1.5 text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        aria-label="Toggle theme"
      ></button>
      <a href="/nick" class="shrink-0 text-sm text-tc-200 transition-colors hover:text-tc-50">
        Change nick
      </a>
      <form method="post" action="/api/logout" class="shrink-0">
        <button
          type="submit"
          class="rounded-lg p-1.5 text-sm text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        >
          Logout
        </button>
      </form>
      {room.slug !== "lobby" && (
        <form method="post" action={`/rooms/${room.slug}/delete`} class="shrink-0" onsubmit="return confirm('Delete this room?');">
          <button
            type="submit"
            class="rounded-lg p-1.5 text-sm text-red-400 transition-colors hover:bg-red-900/30 hover:text-red-300"
            title="Delete room"
          >
            Delete
          </button>
        </form>
      )}
    </header>

    <!-- ─── Content grid ─── -->
    <div class="chat-grid">

      <!-- LEFT SIDEBAR: Rooms -->
      <aside
        class="grid-rooms hidden flex-col overflow-y-auto bg-tc-900 p-3 md:flex"
        data-tab-panel="rooms"
      >
        <div class="mb-2 text-sm font-semibold text-tc-100">Rooms</div>

        <ul
          id="roomsList"
          class="flex flex-col gap-1"
          hx-get={`/rooms/list?current=${encodeURIComponent(room.slug)}`}
          hx-trigger="load, sse:roomsUpdated"
          hx-swap="innerHTML"
        >
          {rooms.map((r) => (
            <li>
              <a
                href={`/rooms/${r.slug}`}
                class:list={[
                  "block rounded-lg px-2 py-1.5 text-sm transition-colors hover:bg-tc-800",
                  r.slug === room.slug ? "bg-tc-700 text-tc-50" : "text-tc-200",
                ]}
              >
                {r.name}
              </a>
            </li>
          ))}
        </ul>

        <form method="post" action="/rooms" class="mt-3 flex gap-2">
          <input
            name="name"
            required
            maxlength="32"
            class="min-w-0 flex-1 rounded-lg border border-tc-700 bg-tc-950 px-2 py-1.5 text-sm text-tc-50 outline-none transition-colors placeholder:text-tc-300 focus:border-tc-500"
            placeholder="New room"
          />
          <button
            class="rounded-lg bg-tc-500 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-tc-400"
            type="submit"
          >
            Create
          </button>
        </form>
      </aside>

      <!-- CENTER: Chat -->
      <section class="grid-chat flex flex-col overflow-hidden" data-tab-panel="chat">
        <div
          id="typing"
          class="h-8 shrink-0 px-3 py-2 text-xs text-tc-300"
        ></div>

        <ol
          id="messages"
          class="flex-1 overflow-y-auto px-3 py-3"
        >
          <li
            id="historySentinel"
            class="py-2 text-center text-xs text-tc-300"
            hx-get={`/rooms/${room.slug}/history?before=${encodeURIComponent(oldest ? oldest.toISOString() : new Date().toISOString())}&limit=50`}
            hx-trigger="revealed"
            hx-swap="outerHTML"
          >
            {oldest ? "Load older messages…" : "No history yet"}
          </li>
          {initialMessages.length === 0 ? (
            <li class="text-sm text-tc-300">No messages yet.</li>
          ) : (
            initialMessages.map((m) => (
              <Fragment set:html={renderMessageLi({ nickname: m.nickname, body: m.body, createdAt: m.createdAt, kind: m.kind })} />
            ))
          )}
        </ol>

        <div
          id="sseSink"
          class="hidden"
          sse-swap="message"
          hx-swap="beforeend"
        ></div>

        <form
          id="composerForm"
          class="flex shrink-0 items-end gap-2 border-t border-tc-800 p-3"
          hx-post={`/rooms/${room.slug}/messages`}
          hx-target="#sseSink"
          hx-swap="beforeend"
          hx-on:submit="setTimeout(()=>{const t=document.getElementById('composerInput'); if(t){t.value=''; t.dispatchEvent(new Event('input',{bubbles:true}));}},0)"
          hx-on:messageSent="this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}"
          hx-on:htmx:afterRequest="if(event.detail.successful){this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}}"
        >
          <div class="relative flex min-w-0 flex-1 flex-col">
            <ul
              id="mentionDropdown"
              role="listbox"
              aria-label="Mention suggestions"
              class="absolute bottom-full left-0 right-0 z-50 mb-1 hidden max-h-48 overflow-y-auto rounded-lg border border-tc-700 bg-tc-900 py-1 shadow-lg"
            ></ul>
            <textarea
              id="composerInput"
              name="body"
              rows="1"
              required
              maxlength="2000"
              autocomplete="off"
              class="min-h-[44px] w-full resize-none rounded-lg border border-tc-700 bg-tc-950 px-3 py-2 text-sm text-tc-50 outline-none transition-colors placeholder:text-tc-300 focus:border-tc-500"
              placeholder={`Message as ${nickname}…`}
              hx-post={`/rooms/${room.slug}/typing`}
              hx-trigger="keyup changed delay:400ms"
              hx-swap="none"
            ></textarea>
          </div>
          <button
            class="h-[44px] rounded-lg bg-tc-500 px-4 text-sm font-medium text-white transition-colors hover:bg-tc-400"
            type="submit"
          >
            Send
          </button>
        </form>
      </section>

      <!-- RIGHT SIDEBAR: Online -->
      <aside
        class="grid-online hidden flex-col overflow-y-auto bg-tc-900 p-3 md:flex"
        data-tab-panel="online"
      >
        <div id="presence">
          <div class="mb-2 text-sm font-semibold text-tc-100">Online</div>
          <div class="text-xs text-tc-300">Loading…</div>
        </div>
      </aside>

    </div>

    <!-- ─── Mobile bottom tabs ─── -->
    <nav class="flex shrink-0 border-t border-tc-800 bg-tc-900 md:hidden">
      <button data-tab-btn="chat" class="flex-1 py-3 text-center text-xs font-medium text-accent transition-colors">
        Chat
      </button>
      <button data-tab-btn="rooms" class="flex-1 py-3 text-center text-xs font-medium text-tc-300 transition-colors">
        Rooms
      </button>
      <button data-tab-btn="online" class="flex-1 py-3 text-center text-xs font-medium text-tc-300 transition-colors">
        Online
      </button>
    </nav>
  </div>

  <!-- Mobile tab switching -->
  <script is:inline>
    (function() {
      var app = document.getElementById('chatApp');
      if (!app) return;

      function isMobile() { return window.innerWidth < 768; }

      function switchTab(tab) {
        app.dataset.activeTab = tab;

        app.querySelectorAll('[data-tab-btn]').forEach(function(btn) {
          var active = btn.dataset.tabBtn === tab;
          btn.className = 'flex-1 py-3 text-center text-xs font-medium transition-colors ' +
            (active ? 'text-accent border-t-2 border-accent' : 'text-tc-300');
        });

        if (!isMobile()) return;
        app.querySelectorAll('[data-tab-panel]').forEach(function(panel) {
          panel.style.display = (panel.dataset.tabPanel === tab) ? 'flex' : 'none';
        });
      }

      app.querySelectorAll('[data-tab-btn]').forEach(function(btn) {
        btn.addEventListener('click', function() { switchTab(btn.dataset.tabBtn); });
      });

      var timer;
      window.addEventListener('resize', function() {
        clearTimeout(timer);
        timer = setTimeout(function() {
          app.querySelectorAll('[data-tab-panel]').forEach(function(p) {
            p.style.display = '';
          });
          if (isMobile()) switchTab(app.dataset.activeTab || 'chat');
        }, 100);
      });

      if (isMobile()) switchTab('chat');

      // Focus the chat input on page load
      const composerInput = document.getElementById('composerInput');
      if (composerInput) {
        composerInput.focus();
      }
    })();
  </script>

  <script is:inline>
    (function () {
      var app = document.getElementById("chatApp");
      var ta = document.getElementById("composerInput");
      var dd = document.getElementById("mentionDropdown");
      var messagesEl = document.getElementById("messages");
      if (!app || !ta || !dd || !messagesEl) return;

      var myNick = app.dataset.chatNickname || "";
      var roomName = app.dataset.roomName || "Talkara";
      var slug = app.dataset.roomSlug || "";

      function mentionsMe(body, nick) {
        if (!body || !nick) return false;
        if (/@everyone\b/i.test(body)) return true;
        var re = /@([^\s@]+)/g;
        var m;
        var nl = nick.toLowerCase();
        while ((m = re.exec(body))) {
          if (m[1].toLowerCase() === nl) return true;
        }
        return false;
      }

      function highlightMentionsIn(root) {
        if (!myNick) return;
        var nodes = root.querySelectorAll
          ? root.querySelectorAll(".message-user .msg-body .mention")
          : [];
        for (var i = 0; i < nodes.length; i++) {
          var span = nodes[i];
          var t = span.textContent || "";
          span.classList.remove("mention-self");
          if (t.toLowerCase() === "@everyone") {
            span.classList.add("mention-self");
          } else if (t.length > 1 && t.slice(1).toLowerCase() === myNick.toLowerCase()) {
            span.classList.add("mention-self");
          }
        }
      }

      function notifyIfMentioned(li) {
        if (!myNick || typeof Notification === "undefined") return;
        var author = li.getAttribute("data-author");
        if (author === myNick) return;
        if (Notification.permission !== "granted") return;
        var bodyEl = li.querySelector(".msg-body");
        var text = bodyEl ? bodyEl.textContent || "" : "";
        if (!mentionsMe(text, myNick)) return;
        var title = "Mentioned in " + roomName;
        var preview = (author ? author + ": " : "") + (text.length > 120 ? text.slice(0, 117) + "…" : text);
        try {
          new Notification(title, { body: preview, icon: "/logo.svg" });
        } catch (e) {}
      }

      function processMessageLi(li) {
        if (!li || !li.classList || !li.classList.contains("message-user")) return;
        highlightMentionsIn(li);
        notifyIfMentioned(li);
      }

      highlightMentionsIn(messagesEl);
      messagesEl.querySelectorAll("li.message-user").forEach(processMessageLi);

      var mo = new MutationObserver(function (muts) {
        muts.forEach(function (m) {
          m.addedNodes.forEach(function (node) {
            if (node.nodeType !== 1) return;
            if (node.matches && node.matches("li.message-user")) processMessageLi(node);
            if (node.querySelectorAll) {
              node.querySelectorAll("li.message-user").forEach(processMessageLi);
            }
          });
        });
      });
      mo.observe(messagesEl, { childList: true, subtree: true });

      var notifyBtn = document.getElementById("mentionNotifyBtn");
      if (notifyBtn) {
        function syncNotifyUi() {
          if (typeof Notification === "undefined") {
            notifyBtn.style.display = "none";
            return;
          }
          var p = Notification.permission;
          notifyBtn.title =
            p === "granted"
              ? "Mention notifications are on"
              : "Click to enable mention notifications";
          notifyBtn.setAttribute("aria-pressed", p === "granted" ? "true" : "false");
        }
        syncNotifyUi();
        notifyBtn.addEventListener("click", function () {
          if (typeof Notification === "undefined") return;
          Notification.requestPermission().then(syncNotifyUi);
        });
      }

      var mentionState = {
        open: false,
        at: -1,
        query: "",
        selected: 0,
        list: /** @type {{ kind: string, insert: string, label: string }[]} */ ([]),
      };

      var namesCache = /** @type {string[] | null} */ (null);
      var namesFetchedAt = 0;
      var NAMES_TTL = 8000;

      function fetchOnlineNames(cb) {
        var now = Date.now();
        if (namesCache && now - namesFetchedAt < NAMES_TTL) {
          cb(namesCache);
          return;
        }
        fetch("/rooms/" + encodeURIComponent(slug) + "/online-names", { credentials: "same-origin" })
          .then(function (r) {
            return r.json();
          })
          .then(function (data) {
            namesCache = data.names && Array.isArray(data.names) ? data.names : [];
            namesFetchedAt = Date.now();
            cb(namesCache);
          })
          .catch(function () {
            cb(namesCache || []);
          });
      }

      function getMentionContext(value, cursor) {
        var before = value.slice(0, cursor);
        var lastAt = before.lastIndexOf("@");
        if (lastAt === -1) return null;
        var afterAt = before.slice(lastAt + 1);
        if (/\s/.test(afterAt)) return null;
        if (afterAt.indexOf("@") !== -1) return null;
        return { start: lastAt, query: afterAt };
      }

      function buildCandidates(query, names, done) {
        var q = (query || "").toLowerCase();
        var out = [];
        var ev = "everyone";
        if (q === "" || ev.indexOf(q) === 0) {
          out.push({ kind: "everyone", insert: "everyone", label: "everyone" });
        }
        for (var i = 0; i < names.length; i++) {
          var n = names[i];
          if (!n) continue;
          if (myNick && n.toLowerCase() === myNick.toLowerCase()) continue;
          if (q !== "" && n.toLowerCase().indexOf(q) !== 0) continue;
          if (n.toLowerCase() === "everyone") continue;
          out.push({ kind: "user", insert: n, label: n });
        }
        done(out);
      }

      function renderDropdown() {
        dd.innerHTML = "";
        if (!mentionState.open || mentionState.list.length === 0) {
          dd.classList.add("hidden");
          return;
        }
        dd.classList.remove("hidden");
        for (var i = 0; i < mentionState.list.length; i++) {
          var item = mentionState.list[i];
          var li = document.createElement("li");
          li.setAttribute("role", "option");
          li.setAttribute("data-idx", String(i));
          li.tabIndex = -1;
          li.className =
            "cursor-pointer px-3 py-1.5 text-sm text-tc-100 " +
            (i === mentionState.selected ? "bg-tc-700" : "hover:bg-tc-800");
          li.textContent = "@" + item.label + (item.kind === "everyone" ? " (all)" : "");
          li.addEventListener("mousedown", function (e) {
            e.preventDefault();
            pickMention(Number(li.getAttribute("data-idx")));
          });
          dd.appendChild(li);
        }
      }

      function closeMention() {
        mentionState.open = false;
        mentionState.at = -1;
        mentionState.list = [];
        dd.classList.add("hidden");
        dd.innerHTML = "";
      }

      function openMention(ctx) {
        mentionState.at = ctx.start;
        mentionState.query = ctx.query;
        mentionState.selected = 0;
        fetchOnlineNames(function (names) {
          buildCandidates(ctx.query, names, function (list) {
            if (list.length === 0) {
              closeMention();
              return;
            }
            mentionState.list = list;
            mentionState.open = true;
            renderDropdown();
          });
        });
      }

      function refreshMention() {
        var v = ta.value;
        var c = ta.selectionStart != null ? ta.selectionStart : v.length;
        var ctx = getMentionContext(v, c);
        if (!ctx) {
          closeMention();
          return;
        }
        if (!mentionState.open || mentionState.at !== ctx.start) {
          openMention(ctx);
        } else {
          mentionState.query = ctx.query;
          fetchOnlineNames(function (names) {
            buildCandidates(ctx.query, names, function (list) {
              mentionState.list = list;
              if (list.length === 0) {
                closeMention();
                return;
              }
              mentionState.selected = Math.min(mentionState.selected, list.length - 1);
              mentionState.open = true;
              renderDropdown();
            });
          });
        }
      }

      function pickMention(idx) {
        if (!mentionState.open || idx < 0 || idx >= mentionState.list.length) return;
        var choice = mentionState.list[idx];
        var v = ta.value;
        var c = ta.selectionStart != null ? ta.selectionStart : v.length;
        var insert = "@" + choice.insert + " ";
        var newVal = v.slice(0, mentionState.at) + insert + v.slice(c);
        ta.value = newVal;
        var pos = mentionState.at + insert.length;
        ta.setSelectionRange(pos, pos);
        ta.focus();
        closeMention();
        ta.dispatchEvent(new Event("input", { bubbles: true }));
      }

      ta.addEventListener("input", function () {
        refreshMention();
      });

      ta.addEventListener("keydown", function (e) {
        if (mentionState.open && mentionState.list.length > 0) {
          if (e.key === "ArrowDown") {
            e.preventDefault();
            mentionState.selected = Math.min(mentionState.selected + 1, mentionState.list.length - 1);
            renderDropdown();
            return;
          }
          if (e.key === "ArrowUp") {
            e.preventDefault();
            mentionState.selected = Math.max(mentionState.selected - 1, 0);
            renderDropdown();
            return;
          }
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            pickMention(mentionState.selected);
            return;
          }
          if (e.key === "Tab") {
            e.preventDefault();
            pickMention(mentionState.selected);
            return;
          }
          if (e.key === "Escape") {
            e.preventDefault();
            closeMention();
            return;
          }
        }
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          ta.form && ta.form.requestSubmit();
        }
      });

      ta.addEventListener("blur", function () {
        setTimeout(function () {
          if (document.activeElement && dd.contains(document.activeElement)) return;
          closeMention();
        }, 150);
      });
    })();
  </script>
</Layout>
