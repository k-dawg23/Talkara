---
import Layout from "../../layouts/Layout.astro";
import { getNickname, getOrSetClientId } from "../../server/cookies";
import { getOrCreateLobby, getRoomBySlug, listRooms } from "../../server/rooms";
import { db } from "../../db/client";
import { messages } from "../../db/schema";
import { eq, desc } from "drizzle-orm";
import { renderMessageLi } from "../../server/render";

export const prerender = false;

const nickname = getNickname(Astro.cookies);
if (!nickname) {
  return Astro.redirect("/nick");
}

getOrSetClientId(Astro.cookies);

await getOrCreateLobby();

const { slug } = Astro.params;
const room = await getRoomBySlug(slug!);
if (!room) {
  return Astro.redirect("/rooms/lobby");
}

const rooms = await listRooms();

const recent = await db
  .select()
  .from(messages)
  .where(eq(messages.roomId, room.id))
  .orderBy(desc(messages.createdAt))
  .limit(50);
const initialMessages = [...recent].reverse();
const oldest = initialMessages[0]?.createdAt ?? null;
---

<Layout title={`${room.name} — Talkara`}>
  <div
    id="chatApp"
    data-active-tab="chat"
    class="flex h-screen flex-col bg-tc-950"
    hx-ext="sse"
    sse-connect={`/rooms/${room.slug}/stream`}
  >
    <!-- ─── Header ─── -->
    <header class="flex shrink-0 items-center gap-3 border-b border-tc-800 bg-tc-900/80 px-4 py-2.5 backdrop-blur">
      <a href="/rooms/lobby" class="shrink-0">
        <img src="/logo.svg" alt="Talkara" class="h-8 w-8 rounded-lg" />
      </a>
      <div class="min-w-0 flex-1">
        <div class="truncate text-base font-semibold text-tc-50">{room.name}</div>
      </div>
      <button
        id="themeToggle"
        onclick="toggleTheme()"
        class="shrink-0 rounded-lg p-1.5 text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        aria-label="Toggle theme"
      ></button>
      <a href="/nick" class="shrink-0 text-sm text-tc-200 transition-colors hover:text-tc-50">
        Change nick
      </a>
      <form method="post" action="/api/logout" class="shrink-0">
        <button
          type="submit"
          class="rounded-lg p-1.5 text-sm text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        >
          Logout
        </button>
      </form>
    </header>

    <!-- ─── Content grid ─── -->
    <div class="chat-grid">

      <!-- LEFT SIDEBAR: Rooms -->
      <aside
        class="grid-rooms hidden flex-col overflow-y-auto bg-tc-900 p-3 md:flex"
        data-tab-panel="rooms"
      >
        <div class="mb-2 text-sm font-semibold text-tc-100">Rooms</div>

        <ul
          id="roomsList"
          class="flex flex-col gap-1"
          hx-get={`/rooms/list?current=${encodeURIComponent(room.slug)}`}
          hx-trigger="load, sse:roomsUpdated"
          hx-swap="innerHTML"
        >
          {rooms.map((r) => (
            <li>
              <a
                href={`/rooms/${r.slug}`}
                class:list={[
                  "block rounded-lg px-2 py-1.5 text-sm transition-colors hover:bg-tc-800",
                  r.slug === room.slug ? "bg-tc-700 text-tc-50" : "text-tc-200",
                ]}
              >
                {r.name}
              </a>
            </li>
          ))}
        </ul>

        <form method="post" action="/rooms" class="mt-3 flex gap-2">
          <input
            name="name"
            required
            maxlength="32"
            class="min-w-0 flex-1 rounded-lg border border-tc-700 bg-tc-950 px-2 py-1.5 text-sm text-tc-50 outline-none transition-colors placeholder:text-tc-300 focus:border-tc-500"
            placeholder="New room"
          />
          <button
            class="rounded-lg bg-tc-500 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-tc-400"
            type="submit"
          >
            Create
          </button>
        </form>
      </aside>

      <!-- CENTER: Chat -->
      <section class="grid-chat flex flex-col overflow-hidden" data-tab-panel="chat">
        <div
          id="typing"
          class="h-8 shrink-0 px-3 py-2 text-xs text-tc-300"
        ></div>

        <ol
          id="messages"
          class="flex-1 overflow-y-auto px-3 py-3"
        >
          <li
            id="historySentinel"
            class="py-2 text-center text-xs text-tc-300"
            hx-get={`/rooms/${room.slug}/history?before=${encodeURIComponent(oldest ? oldest.toISOString() : new Date().toISOString())}&limit=50`}
            hx-trigger="revealed"
            hx-swap="outerHTML"
          >
            {oldest ? "Load older messages…" : "No history yet"}
          </li>
          {initialMessages.length === 0 ? (
            <li class="text-sm text-tc-300">No messages yet.</li>
          ) : (
            initialMessages.map((m) => (
              <Fragment set:html={renderMessageLi({ nickname: m.nickname, body: m.body, createdAt: m.createdAt, kind: m.kind })} />
            ))
          )}
        </ol>

        <div
          id="sseSink"
          class="hidden"
          sse-swap="message"
          hx-swap="beforeend"
        ></div>

        <form
          id="composerForm"
          class="flex shrink-0 items-end gap-2 border-t border-tc-800 p-3"
          hx-post={`/rooms/${room.slug}/messages`}
          hx-target="#sseSink"
          hx-swap="beforeend"
          hx-on:submit="setTimeout(()=>{const t=document.getElementById('composerInput'); if(t){t.value=''; t.dispatchEvent(new Event('input',{bubbles:true}));}},0)"
          hx-on:messageSent="this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}"
          hx-on:htmx:afterRequest="if(event.detail.successful){this.reset(); const t=this.querySelector('textarea[name=body]'); if(t){t.dispatchEvent(new Event('input'));}}"
        >
          <textarea
            id="composerInput"
            name="body"
            rows="1"
            required
            maxlength="2000"
            class="min-h-[44px] flex-1 resize-none rounded-lg border border-tc-700 bg-tc-950 px-3 py-2 text-sm text-tc-50 outline-none transition-colors placeholder:text-tc-300 focus:border-tc-500"
            placeholder={`Message as ${nickname}…`}
            hx-post={`/rooms/${room.slug}/typing`}
            hx-trigger="keyup changed delay:400ms"
            hx-swap="none"
            hx-on:keydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); this.form.requestSubmit();}"
          ></textarea>
          <button
            class="h-[44px] rounded-lg bg-tc-500 px-4 text-sm font-medium text-white transition-colors hover:bg-tc-400"
            type="submit"
          >
            Send
          </button>
        </form>
      </section>

      <!-- RIGHT SIDEBAR: Online -->
      <aside
        class="grid-online hidden flex-col overflow-y-auto bg-tc-900 p-3 md:flex"
        data-tab-panel="online"
      >
        <div id="presence">
          <div class="mb-2 text-sm font-semibold text-tc-100">Online</div>
          <div class="text-xs text-tc-300">Loading…</div>
        </div>
      </aside>

    </div>

    <!-- ─── Mobile bottom tabs ─── -->
    <nav class="flex shrink-0 border-t border-tc-800 bg-tc-900 md:hidden">
      <button data-tab-btn="chat" class="flex-1 py-3 text-center text-xs font-medium text-accent transition-colors">
        Chat
      </button>
      <button data-tab-btn="rooms" class="flex-1 py-3 text-center text-xs font-medium text-tc-300 transition-colors">
        Rooms
      </button>
      <button data-tab-btn="online" class="flex-1 py-3 text-center text-xs font-medium text-tc-300 transition-colors">
        Online
      </button>
    </nav>
  </div>

  <!-- Mobile tab switching -->
  <script is:inline>
    (function() {
      var app = document.getElementById('chatApp');
      if (!app) return;

      function isMobile() { return window.innerWidth < 768; }

      function switchTab(tab) {
        app.dataset.activeTab = tab;

        app.querySelectorAll('[data-tab-btn]').forEach(function(btn) {
          var active = btn.dataset.tabBtn === tab;
          btn.className = 'flex-1 py-3 text-center text-xs font-medium transition-colors ' +
            (active ? 'text-accent border-t-2 border-accent' : 'text-tc-300');
        });

        if (!isMobile()) return;
        app.querySelectorAll('[data-tab-panel]').forEach(function(panel) {
          panel.style.display = (panel.dataset.tabPanel === tab) ? 'flex' : 'none';
        });
      }

      app.querySelectorAll('[data-tab-btn]').forEach(function(btn) {
        btn.addEventListener('click', function() { switchTab(btn.dataset.tabBtn); });
      });

      var timer;
      window.addEventListener('resize', function() {
        clearTimeout(timer);
        timer = setTimeout(function() {
          app.querySelectorAll('[data-tab-panel]').forEach(function(p) {
            p.style.display = '';
          });
          if (isMobile()) switchTab(app.dataset.activeTab || 'chat');
        }, 100);
      });

      if (isMobile()) switchTab('chat');
    })();
  </script>
</Layout>
