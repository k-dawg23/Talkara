---
import Layout from "../layouts/Layout.astro";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
---

<Layout title="Pick a nickname — Talkara">
  <main class="relative flex min-h-screen flex-col items-center justify-center px-4 py-10">
    <div class="absolute right-4 top-4 z-20">
      <button
        id="themeToggle"
        onclick="toggleTheme()"
        class="rounded-lg p-1.5 text-tc-200 transition-colors hover:bg-tc-800 hover:text-tc-50"
        aria-label="Toggle theme"
      ></button>
    </div>
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -left-1/4 top-0 h-[60%] w-[60%] rounded-full bg-tc-500/10 blur-3xl"></div>
      <div class="absolute -right-1/4 bottom-0 h-[50%] w-[50%] rounded-full bg-accent/5 blur-3xl"></div>
    </div>

    <div class="relative z-10 flex w-full max-w-sm flex-col items-center gap-8">
      <img src="/logo.svg" alt="Talkara" class="h-24 w-24 rounded-2xl shadow-2xl shadow-tc-500/20" />

      <div class="flex w-full flex-col gap-1 text-center">
        <h1 class="text-2xl font-bold tracking-tight text-tc-50">Pick a nickname</h1>
        <p class="text-sm text-tc-200">No passwords. Just jump into chat.</p>
      </div>

      <form method="post" action="/api/nick" class="flex w-full flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <label class="text-sm font-medium text-tc-100" for="nickname">Nickname</label>
          <input
            id="nickname"
            name="nickname"
            autocomplete="nickname"
            maxlength="24"
            minlength="2"
            required
            class="w-full rounded-lg border border-tc-700 bg-tc-900 px-3 py-2.5 text-tc-50 outline-none transition-colors placeholder:text-tc-300 focus:border-tc-500"
            placeholder="Alex"
          />
        </div>

        {error ? <p class="text-sm text-red-400">{error}</p> : null}

        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-tc-500 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-tc-500/25 transition-colors hover:bg-tc-400"
        >
          Continue
        </button>
      </form>
    </div>
  </main>
</Layout>
