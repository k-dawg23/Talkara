---
type Props = {
  title?: string;
};

const { title = "Talkara" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-zinc-950 text-zinc-100">
    <slot />

    <!-- Load HTMX and SSE extension as global scripts for maximum browser compatibility -->
    <script src="/vendor/htmx.min.js" is:inline></script>
    <script src="/vendor/htmx-sse.min.js" is:inline></script>
    <script is:inline>
      // If these aren't present, realtime won't work; fail loudly in console.
      if (!window.htmx) console.error("Talkara: HTMX failed to load");
    </script>
  </body>
</html>

