---
import "../styles/global.css";

type Props = {
  title?: string;
};

const { title = "Talkara" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-tc-950 text-tc-50">
    <slot />

    <script src="/vendor/htmx.min.js" is:inline></script>
    <script src="/vendor/htmx-sse.min.js" is:inline></script>
    <script is:inline>
      if (!window.htmx) console.error("Talkara: HTMX failed to load");
    </script>
  </body>
</html>
