---
type Props = {
  title?: string;
};

const { title = "Talkara" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-zinc-950 text-zinc-100">
    <slot />

    <script type="module">
      import "htmx.org";
      import "htmx-ext-sse";
    </script>
  </body>
</html>

