---
type Props = {
  title?: string;
};

const { title = "Talkara" } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-zinc-950 text-zinc-100">
    <slot />

    <!-- Load HTMX and SSE extension as global scripts for maximum browser compatibility -->
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <script src="https://unpkg.com/htmx-ext-sse@2.2.4/sse.js"></script>
  </body>
</html>

